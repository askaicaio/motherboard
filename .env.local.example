# =============================================================
# CAIO Internal Dashboard — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in real values.
# Only @chiefaiofficer.com Google accounts can access this app.

# ---- Database (Supabase) ----
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- NextAuth ----
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ---- Google OAuth (for admin login — @chiefaiofficer.com only) ----
# Create at: https://console.cloud.google.com/apis/credentials
# Set authorized redirect: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAIL_DOMAIN=chiefaiofficer.com

# ---- n8n Orchestration ----
N8N_BASE_URL=https://n8n.example.com
N8N_WEBHOOK_SECRET=shared-hmac-secret-for-callback-verification

# ---- Provisioning Mode ----
# "mock" = simulated responses for development
# "live" = real n8n webhook calls
PROVISIONING_MODE=mock

# ---- Email (Resend) ----
# Sign up at https://resend.com and verify your domain
RESEND_API_KEY=re_your_api_key
EMAIL_FROM_ADDRESS=onboarding@chiefaiofficer.com
EMAIL_FROM_NAME=CAIO Onboarding

# ---- Slack (notifications + provisioning) ----
# Bot Token: Create a Slack app at https://api.slack.com/apps
# Scopes needed: chat:write, channels:manage, users:read, users:write
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_WORKSPACE_ID=T0123456789
# Incoming Webhook (alternative to Bot Token for simple notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
# Channel for provisioning notifications
SLACK_NOTIFICATIONS_CHANNEL=#ops-onboarding

# ---- Google Workspace (provisioning) ----
# Service account with domain-wide delegation
# Admin SDK must be enabled in Google Cloud Console
GOOGLE_WORKSPACE_CUSTOMER_ID=C0123abc
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_DELEGATED_ADMIN_EMAIL=admin@chiefaiofficer.com

# ---- ClickUp ----
CLICKUP_API_KEY=pk_your_api_key
CLICKUP_WORKSPACE_ID=your_workspace_id

# ---- GoHighLevel ----
# Canonical name is GHL_API_TOKEN. GHL_API_KEY is also accepted as a
# fallback so existing Vercel projects keyed under the old name still work.
GHL_API_TOKEN=your-ghl-api-token
GHL_LOCATION_ID=your-location-id

# ---- Make (Automations tab) ----
# API token from Make: Profile -> API/Access -> generate a token with at least
# scenarios:read scope. Required for the Make card's "API Key Integrated"
# status and the Make scenario sync. Zone + org default to us1 / 1193307 and
# only need setting if the Make account ever moves.
MAKE_API_TOKEN=your-make-api-token
MAKE_ZONE=us1
MAKE_ORG_ID=1193307

# ---- Circle ----
CIRCLE_API_KEY=your-circle-api-key
CIRCLE_COMMUNITY_ID=your-community-id

# ---- 1Password ----
# Service Account Token (Business plan) or Connect Server Token
OP_SERVICE_ACCOUNT_TOKEN=your-1password-service-account-token

# ---- Zoom ----
# Server-to-Server OAuth app: https://marketplace.zoom.us/develop/create
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# ---- Company Reports (Strategic Growth Reports) ----
# Mode: "mock" returns sample data after a delay; "live" uses real APIs.
# Defaults to mock if either API key is missing.
REPORTS_MODE=mock

# Anthropic API — used for deep research with web_search tool
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5

# Gamma Generate API (closed beta — request access via Gamma support)
# Docs: https://developers.gamma.app
GAMMA_API_KEY=your-gamma-api-key
GAMMA_API_BASE_URL=https://public-api.gamma.app/v0.2
GAMMA_THEME_NAME=Default

# ---- Partner Program (affiliate system) ----
# Stripe restricted key with read+write on Products, Prices, Checkout
# Sessions, and Webhook Endpoints. Generate at:
# https://dashboard.stripe.com/apikeys (use a Restricted Key, never the
# Secret Key, in production). Test mode (sk_test_*) is fine for previews.
STRIPE_SECRET_KEY=sk_test_your-stripe-key

# Stripe webhook signing secret (whsec_*) from the webhook endpoint you
# create in the Stripe dashboard pointing at
# {NEXT_PUBLIC_APP_URL}/api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Random URL-safe secret used to authenticate the cron handlers
# (already in use by sync-ghl-campaigns; included here for completeness).
CRON_SECRET=generate-a-32-byte-random-string

# Optional override for the partner-facing URL base used when generating
# referral links shown in the admin UI. Defaults to NEXT_PUBLIC_APP_URL.
# Eventually set to https://b2b.chiefaiofficer.com once that domain is
# pointed at this app in Vercel.
PARTNER_PROGRAM_BASE_URL=

# The GHL book-a-call page an affiliate's referral link (/r?aff=CODE) sends
# prospects to by default. The ref code is appended as ?aff_id=CODE — configure
# your GHL booking page/funnel to capture that param into a contact custom field.
AFFILIATE_BOOKING_URL=

# ---- Vercel Blob (file storage) ----
# Public store ("affiliates-system") — affiliate marketing resources/downloads.
# Auto-added by Vercel when you connect a Public Blob store to the project.
BLOB_READ_WRITE_TOKEN=
# Separate PRIVATE store ("affiliates-tax-forms") — W-9/W-8BEN PDFs. When set,
# tax forms are stored privately and only served via /api/partners/[id]/tax-form
# (admin-gated). When connecting the private store in Vercel, name its token
# env var exactly TAX_BLOB_READ_WRITE_TOKEN so it doesn't clash with the public one.
TAX_BLOB_READ_WRITE_TOKEN=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CAIO Internal Dashboard
